# ─────────────────────────────────────────────────────────────────────────────
# Razorpay OAuth (Partner Connect) — per-restaurant payment gateway
# Create the Razorpay Partner app in the Razorpay dashboard and copy the
# Client ID / Client Secret here. Set MODE=test while validating, then flip
# to MODE=live for production.
# ─────────────────────────────────────────────────────────────────────────────
RAZORPAY_OAUTH_CLIENT_ID=
RAZORPAY_OAUTH_CLIENT_SECRET=
RAZORPAY_OAUTH_MODE=test
# Must match the redirect URI whitelisted on the Razorpay Partner app, e.g.
#   https://yourdomain.com/api/manage/payments/razorpay/callback
RAZORPAY_OAUTH_REDIRECT_URI=
# Webhook secret configured on the Razorpay Partner app (NOT the per-merchant
# one — partner webhooks are signed with this secret).
RAZORPAY_OAUTH_WEBHOOK_SECRET=

# AES-256-GCM key used to encrypt OAuth tokens at rest in the database.
# Generate with: openssl rand -base64 32
PAYMENTS_ENC_KEY=qzWmGkI6FwU+QArAM88rUUUh3zzc1r0hLsNf6nIF84w=
